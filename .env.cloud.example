# Pedkai Cloud Environment Configuration
# Copy to .env on the backend VM and fill in real values

# Application
APP_NAME=Pedkai
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=<generate-a-strong-random-key>

# API
API_PREFIX=/api/v1
PEDKAI_BACKEND_PORT=8000
ALLOWED_ORIGINS='["https://pedk.ai"]'

# Database (PostgreSQL + pgvector on VM 2)
# Replace <db-private-ip> with the private IP of the database VM
DATABASE_URL=postgresql+asyncpg://pedkai:<db-password>@<db-private-ip>:5432/pedkai
METRICS_DATABASE_URL=postgresql+asyncpg://pedkai:<db-password>@<db-private-ip>:5432/pedkai_metrics
DB_SSL_MODE=disable

# psycopg2 DSNs (used by seed scripts)
GRAPH_DB_DSN=host=<db-private-ip> port=5432 dbname=pedkai user=pedkai password=<db-password>
METRICS_DB_DSN=host=<db-private-ip> port=5432 dbname=pedkai_metrics user=pedkai password=<db-password>

# Database credentials
POSTGRES_USER=pedkai
POSTGRES_PASSWORD=<db-password>

# Gemini LLM
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.0-flash

# Kafka (runs on same VM via Docker Compose)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=pedkai-consumers

# Multi-tenancy
DEFAULT_TENANT_ID=pedkai_telco2_01

# Vector embeddings
EMBEDDING_DIMENSION=3072

# LLM Provider — "on-prem" for Ollama/TSLAM, "gemini" for Google Gemini
PEDKAI_LLM_PROVIDER=on-prem
PEDKAI_ONPREM_URL=http://host.docker.internal:11434
PEDKAI_ONPREM_MODEL=tslam-mini-2b
PEDKAI_ONPREM_EMBED_MODEL=tslam-mini-2b

# Data store root (for Telco2 Parquet files on DB VM)
PEDKAI_DATA_STORE_ROOT=/data/telco2

# Auth defaults (change these!)
ADMIN_PASSWORD=<strong-admin-password>
OPERATOR_PASSWORD=<strong-operator-password>

# Sleeping Cell Detector
SLEEPING_CELL_ENABLED=true
SLEEPING_CELL_SCAN_INTERVAL_SECONDS=300

# AI Maturity Level (1=Shadow, 2=Supervised, 3=Autonomous)
AI_MATURITY_LEVEL=2

# Frontend uses relative paths — no NEXT_PUBLIC_API_BASE_URL needed for production.
# For local dev only: set NEXT_PUBLIC_API_BASE_URL=http://localhost:8000 in .env.local
